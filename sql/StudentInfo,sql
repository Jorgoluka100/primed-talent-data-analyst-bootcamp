-- ======================================================
-- UNIVERSITY ENROLLMENT SYSTEM SCHEMA
-- ======================================================

-- 1. Create Students Table
-- Purpose: Stores unique identification and contact info for all students.
CREATE TABLE StudentSystem (
    StudentID INT PRIMARY KEY,
    FirstName VARCHAR(50) NOT NULL,
    LastName VARCHAR(50) NOT NULL,
    Email VARCHAR(100) UNIQUE
);

-- 2. Create Courses Table
-- Purpose: Maintains a catalog of available academic courses and their credit values.
CREATE TABLE CoursesSystem (
    CourseID INT PRIMARY KEY,
    CourseName VARCHAR(100) NOT NULL,
    Credits INT CHECK (Credits > 0)
);

-- 3. Create Enrollments Table
-- Purpose: A bridge table that links students to the courses they are taking.
-- It records the specific grade a student earned in a specific course.
CREATE TABLE EnrollmentsSystem (
    EnrollmentID INT PRIMARY KEY,
    StudentID INT,
    CourseID INT,
    Grade VARCHAR(2),
    -- Constraint: Ensures that a student exists before they can enroll
    FOREIGN KEY (StudentID) REFERENCES Students(StudentID),
    -- Constraint: Ensures that the course exists in the catalog
    FOREIGN KEY (CourseID) REFERENCES Courses(CourseID)
);

-- 1. Insert Students
