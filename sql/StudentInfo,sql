-- 3. Insert Enrollments
-- We link the StudentID and CourseID here
INSERT INTO EnrollmentsSystem (EnrollmentID, StudentID, CourseID, Grade) VALUES 
(501, 1, 101, 'A'),   -- Alice in SQL
(502, 1, 102, 'B+'),  -- Alice in Data Structures
