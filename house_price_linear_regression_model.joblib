   "source": [
    "# Scatter Plot\n",
    "plt.figure(figsize=(8,4))\n",
    "plt.scatter(df['Gr Liv Area'], df['SalePrice'], alpha=0.3)\n",
    "plt.xlabel('Above-Grade Living Area (sq ft)')\n",
    "plt.ylabel('Sale Price')\n",
    "plt.title('Living Area vs Sale Price')\n",
    "plt.tight_layout()\n",
    "plt.show()"
