    "#Box Plot\n",
    "plt.figure(figsize=(8,4))\n",
    "sns.boxplot(x='Overall Qual', y='SalePrice', data=df)\n",
    "plt.xlabel('Overall Quality')\n",
    "plt.ylabel('Sale Price')\n",
    "plt.title('Overall Quality vs Sale Price')\n",
    "plt.tight_layout()\n",
    "plt.show()"
