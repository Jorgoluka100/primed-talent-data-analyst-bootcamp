   "source": [
    "# K FOLD CROSS VALIDATION\n",
    "#This splits the data into K parts, trains on K-1, and tests on the remaining fold. \n",
    "#This is repeated K times so every sample gets tested once. It gives a more reliable estimate of model \n",
    "#performance than a single train/ test split\n",
    "\n",
    "from sklearn.model_selection import cross_val_score\n",
    "# 5 - fold cross validation\n",
    "cv_lr = cross_val_score(LinearRegression(), X, y, cv=5, scoring='r2')\n",
    "print(f'Linear Regression CV R2: {cv_lr.mean():.4f} + {cv_lr.std():.4f}')\n",
    "print(f'\\nPer Fold scores: {[f\"{s:.4f}\" for s in cv_lr]}')\n",
    " "
   ]
  },
