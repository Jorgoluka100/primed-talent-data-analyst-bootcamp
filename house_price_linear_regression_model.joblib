    "plt.plot([y_test.min(), y_test.max()], [y_test.min(), y_test.max()], color='red', linestyle='--')  # Add a reference line\n",
    "plt.xlabel('Actual Log(SalePrice)')\n",
    "plt.ylabel('Predicted Log(SalePrice)')\n",
